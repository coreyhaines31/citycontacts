<%= render partial: "shared/heading", locals: { title: 'My Account' } %>

<div class="max-w-xl mx-auto sm:py-12">
  <h3 class="mb-2 text-2xl leading-9 font-extrabold text-gray-900">Subscription</h3>
  <div class="flex">
    <div class="flex-auto">
      Billing Status: <%= current_user.paying_customer? ? 'Active' : 'Inactive' %><br>
    </div>
    <div class="flex-shrink">
      <%= button_to 'Manage >>', billing_portal_index_path, method: :post, data: { turbo: false }, class: "font-medium text-primary-500" %>
    </div>
  </div>

  <%= form_for(current_user, url: account_path(current_user.id), method: 'patch', html: {class: "mt-8", autocomplete: 'off'}) do |f| %>
    <div>
      <h3 class="mb-2 text-2xl leading-9 font-extrabold text-gray-900">Profile</h3>
      <div class="mb-2 border border-gray-300 rounded-md px-3 py-2">
        <label for="email" class="block text-xs font-medium text-gray-900">Email</label>
        <input type="text" required="true" name="user[email]" id="user_email" class="block w-full border-0 p-0 text-gray-900 placeholder-gray-500 focus:ring-0 sm:text-sm" placeholder="<%= current_user.email %>">
      </div>

      <div class="mb-2 border border-gray-300 rounded-md px-3 py-2">
        <label for="password" class="block text-xs font-medium text-gray-900">Password</label>
        <input type="password" autocomplete="new-password" name="user[password]" id="user_password" class="block w-full border-0 p-0 text-gray-900 placeholder-gray-500 focus:ring-0 sm:text-sm">
      </div>

      <button type="submit" data-turbo="false" class="mt-4 group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
        <span class="absolute left-0 inset-y-0 flex items-center pl-3">
          <!-- Heroicon name: solid/lock-closed -->
          <svg class="h-5 w-5 text-primary-500 group-hover:text-primary-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="white" aria-hidden="true">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
          </svg>
        </span>
        Save
      </button>
    </div>
  <% end %>

  <div class="mt-8">
    <h3 class="mb-2 text-2xl leading-9 font-extrabold text-gray-900">Social Connections</h3>
    <% twitter_profile = current_user.user_social_profiles.find_by(social_media_type: 'twitter') %>
    <div class="mb-4 p-4 border border-gray-300 rounded-md">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <svg class="h-6 w-6 text-[#1DA1F2]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"></path>
          </svg>
          <span class="ml-2 text-gray-900">Twitter</span>
        </div>
        <% if twitter_profile %>
          <div class="flex items-center">
            <span class="text-sm text-gray-500 mr-2">Connected as <%= twitter_profile.social_media_user_id %></span>
            <%= button_to 'Disconnect', social_connection_disconnect_path(provider: 'twitter'), 
                method: :delete, 
                data: { turbo_confirm: 'Are you sure you want to disconnect your Twitter account?' },
                class: "text-sm text-red-600 hover:text-red-800" %>
          </div>
        <% else %>
          <%= link_to twitter_login_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-[#1DA1F2] hover:bg-[#1a8cd8] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#1DA1F2]" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"></path>
            </svg>
            Connect Twitter
          <% end %>
        <% end %>
      </div>

      <% if twitter_profile %>
        <div class="mt-4 space-y-2">
          <%= button_to 'Refresh Location Data', refresh_locations_social_connections_path,
              method: :post,
              class: "w-full px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>

          <%= button_to 'Create City Connections', create_city_connections_social_connections_path,
              method: :post,
              class: "w-full px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        </div>
      <% end %>
    </div>

    <!-- Twitter Followers Location Scraping -->
    <div class="mt-6 p-4 border border-purple-200 rounded-md bg-purple-50">
      <h4 class="text-lg font-medium text-gray-900 mb-2">🎯 Scrape Twitter Followers' Locations</h4>
      <p class="text-sm text-gray-600 mb-4">
        <strong>Get real follower location data!</strong> Enter a Twitter username to extract location information from their followers' profiles.
      </p>

      <%= form_with url: scrape_profile_social_connections_path, method: :post, local: true, class: "space-y-3" do |form| %>
        <div>
          <%= form.text_field :twitter_url,
              placeholder: "https://twitter.com/username or @username",
              required: true,
              class: "w-full px-3 py-2 border border-purple-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
        </div>

        <%= form.submit "Scrape Followers' Locations",
            class: "w-full px-4 py-2 text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
      <% end %>

      <div class="mt-3 p-3 bg-purple-100 rounded-md">
        <div class="text-xs text-purple-800 space-y-1">
          <p><strong>✨ What this does:</strong> Scrapes up to 50 followers and extracts location data from their profiles</p>
          <p><strong>💡 Examples:</strong> twitter.com/elonmusk, @elonmusk, elonmusk</p>
          <p><strong>⚡ Cost:</strong> ~$0.01 per 1000 followers via Apify API</p>
          <p><strong>🔧 Setup needed:</strong> Apify API token required (get free account at apify.com)</p>
        </div>
      </div>
    </div>
  </div>
</div>
